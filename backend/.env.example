# =========================
# SERVER
# =========================
PORT=3001
NODE_ENV=development

# =========================
# DATABASE (PostgreSQL via Prisma)
# =========================
# Used by Prisma for migrations and queries

DATABASE_URL="postgresql://postgres:argentine@localhost:5432/solvia_admin"
# Direct connection (same as DATABASE_URL for local; differs on serverless)
DATABASE_DIRECT_URL="postgresql://postgres:argentine@localhost:5432/solvia_admin"

# =========================
# REDIS (Session & Cache)
# =========================
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=redis_secret

# =========================
# CORS
# =========================
CORS_ORIGIN=http://localhost:3000

# =========================
# JWT (Authentication)
# =========================
# REQUIRED - Generate with: openssl rand -base64 64
JWT_SECRET=change_me_to_a_strong_random_secret_at_least_64_chars_long
JWT_ISSUER=solvia-admin
JWT_ACCESS_TOKEN_EXPIRATION=15m
JWT_REFRESH_TOKEN_EXPIRATION=30d

# =========================
# AUTH SECURITY POLICY
# =========================
# Refresh token TTL in days
AUTH_REFRESH_TOKEN_TTL_DAYS=30
# Login brute-force window in seconds
AUTH_LOGIN_WINDOW_SECONDS=900
# Max failed login attempts before lockout
AUTH_MAX_LOGIN_ATTEMPTS=10
# Token blacklist TTL in seconds (31 days)
AUTH_TOKEN_BLACKLIST_TTL_SECONDS=2678400
# Session cache TTL in seconds
AUTH_SESSION_CACHE_TTL_SECONDS=300

# =========================
# THROTTLE (Global rate limiting)
# =========================
# TTL window in milliseconds
THROTTLE_RATE_LIMIT_TTL=60000
# Max requests per TTL window
THROTTLE_RATE_LIMIT_MAX=100
